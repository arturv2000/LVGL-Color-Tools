{
  "name": "vscode-lvgl-color-tools",
  "displayName": "LVGL Color Tools",
  "description": "LVGL-aware color decorators and color picker support for C/C++ projects in VS Code.",
  "version": "0.1.0",
  "publisher": "local-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arturv2000/LVGL-Color-Tools.git"
  },
  "homepage": "https://github.com/arturv2000/LVGL-Color-Tools",
  "bugs": {
    "url": "https://github.com/arturv2000/LVGL-Color-Tools/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "lvgl",
    "color",
    "embedded",
    "c",
    "cpp",
    "vscode"
  ],
  "files": [
    "out/**/*",
    "readme.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "LVGL Color Tools",
      "properties": {
        "lvglColorTools.enableColorMakeMacro": {
          "type": "boolean",
          "default": true,
          "description": "Enable color decorators and picker editing for LV_COLOR_MAKE(r, g, b)."
        },
        "lvglColorTools.enablePaletteDecorators": {
          "type": "boolean",
          "default": false,
          "description": "Enable decorator-only support for lv_palette_main, lv_palette_lighten, and lv_palette_darken with literal arguments."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "test": "npm run compile && npm run compile:test && node --test out-test/test/lvglColorCore.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.3.2",
    "typescript": "^5.8.3"
  }
}
